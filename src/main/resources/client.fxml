<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>


<AnchorPane prefHeight="500.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.realtimeauctionsystem.ClientViewController">
   <children>
      <Button layoutX="326.0" layoutY="27.0" mnemonicParsing="false" onAction="#handleDisConnectBtn" prefHeight="26.0" prefWidth="201.0" text="Disconnect    Button" />
      <Label fx:id="lblItemName" layoutX="18.0" layoutY="82.0" prefHeight="34.0" prefWidth="238.0" style="-fx-background-radius: 30; -fx-background-color: white;" text="Item Name" textAlignment="JUSTIFY">
         <opaqueInsets>
            <Insets left="4.0" />
         </opaqueInsets>
      </Label>
      <Label fx:id="lblHighestBid" layoutX="307.0" layoutY="82.0" prefHeight="34.0" prefWidth="238.0" style="-fx-background-radius: 30; -fx-background-color: white;" text="Highest Bid" />
      <TextField fx:id="txtUsername" layoutX="18.0" layoutY="28.0" onAction="#handleUsername" prefHeight="26.0" prefWidth="285.0" promptText="Username" />
      <TextArea fx:id="txtArea" layoutX="18.0" layoutY="127.0" prefHeight="200.0" prefWidth="572.0" promptText="messages" />
      <TextField fx:id="txtField" layoutX="18.0" layoutY="348.0" prefHeight="34.0" prefWidth="406.0" promptText="...." />
      <Button layoutX="246.0" layoutY="406.0" mnemonicParsing="false" onAction="#placeBid" prefHeight="34.0" prefWidth="160.0" text="Place Bid" />
   </children>
</AnchorPane>
